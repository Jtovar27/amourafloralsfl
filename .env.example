# ── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Dashboard → Project Settings → API → service_role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Dashboard → Project Settings → API → anon/public key
# Sent to the admin browser via /api/admin/config so the admin login page can
# initialise the Supabase JS client. Anon keys are safe to expose; RLS still applies.
SUPABASE_ANON_KEY=eyJ...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
# Must be a verified sender domain in your Resend account
FROM_EMAIL=Amoura Florals <orders@amouraflorals.com>
# Where admin order notifications are sent
ADMIN_EMAIL=amourafloralsco@gmail.com

# ── Site URL ──────────────────────────────────────────────────────────────────
# No trailing slash. Used for Stripe redirect URLs.
# Local dev: http://localhost:3000
# Production: https://amourafloralsfl.vercel.app  (or your custom domain)
SITE_URL=https://yourdomain.com

# ── Tax (optional override) ───────────────────────────────────────────────────
# Defaults to 0.07 (7% FL). Adjust to your exact local rate.
# TAX_RATE=0.07
